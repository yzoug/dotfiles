# starship config
# zoug
#
# show time
[time]
disabled = false
format = '´ëö [$time]($style) '
{{ if eq .chezmoi.hostname "zougArch" -}}
# ansi colors: https://i.sstatic.net/KTSQa.png
style = 'bold 208'
{{- else if eq .chezmoi.hostname "vogsphere" -}}
style = 'bold 219'
{{- else if eq .chezmoi.hostname "zougecov" -}}
style = 'bold 22'
{{- end }}

# battery shown in yellow below 30%, red below 20%
[[battery.display]]
threshold = 30
style = 'bold yellow'
[[battery.display]]
threshold = 20
style = 'bold red'

# Replace the 'ÔØ»' symbol in the prompt with 'Ô×£'
[character] # The name of the module we are configuring is 'character'
success_symbol = '[Ô×£](bold green)' # The 'success_symbol' segment is being set to 'Ô×£' with the color 'bold green'

