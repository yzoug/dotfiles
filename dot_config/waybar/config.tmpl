[{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "height": 44,
    "modules-left": [
        "custom/logo",
        "sway/workspaces"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "tray",
        {{ if ne .chezmoi.hostname "vogsphere" -}}
        "backlight",
        "battery",
        {{- end }}
        "wireplumber"
    ],
    "sway/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "default": "Όσ▒",
            "1": "ΎΤΚ  1",
            "2": "ΎΞψ  2",
            "3": "≤░Ι╣  3",
            "4": "≤░Θ░  4",
            "5": "≤░Οη  5",
            "6": "6",
            "7": "≤░ΝΗ  7",
            "8": "≤░φ╣  8",
            "9": "ΎΑΒ  9",
            "active": "≤▒Υ╗",
            "urgent": "≤▒Υ╗"
        },
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "tray": {
        "spacing": 10
    },
    "custom/logo": {
        "format": " ΎΝΔ ",
        "tooltip": false,
        "on-click": "~/.config/rofi/launchers/misc/launcher.sh &"
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "≤░Γ░",
        "tooltip-format": "Volume : {volume}%",
        "format-muted": "≤░ζθ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": ["ΎΑο","ΎΑπ","ΎΑρ"]
        },
        "on-click": "pamixer -t",
        "scroll-step": 1
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["≤░δσ","≤▒σΟ","≤▒σΠ","≤▒σΡ","≤▒σΣ","≤▒σΤ","≤▒σΥ","≤▒σΦ","≤▒σΧ","≤▒σΨ","≤░δρ"]
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": {
            "charging": [
                "≤░λε",
                "≤░ΓΗ",
                "≤░ΓΘ",
                "≤░ΓΙ",
                "≤░λζ",
                "≤░ΓΚ",
                "≤░λη",
                "≤░ΓΛ",
                "≤░ΓΜ",
                "≤░ΓΖ"
            ],
            "default": [
                "≤░Β║",
                "≤░Β╗",
                "≤░Β╝",
                "≤░Β╜",
                "≤░Β╛",
                "≤░Β┐",
                "≤░ΓΑ",
                "≤░ΓΒ",
                "≤░ΓΓ",
                "≤░Β╣"
            ]
        },
        "format-full": "Charged ΎΔπ",
        "interval": 30,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "tooltip": false
    }
},
{
    "layer": "bottom",
    "position": "bottom",
    "spacing": 0,
    "height": 44,
    "modules-left": [],
    "modules-center": [
        "memory",
        "cpu",
        "custom/ip",
        "network",
        "clock",
        "mpris"
    ],
    "modules-right": [],
    "cpu": {
        "format": "ΎΤ╝  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
        "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
        "on-click": "alacritty -e btop",
        "interval": 5
    },
    "memory": {
        "format": "Ό┐Ζ  {}%",
        "on-click": "alacritty -e btop",
        "interval": 10
    },
    "clock": {
        "tooltip-format": "{calendar}",
        "format": "ΎΡ║  {:%d %b %Y %I:%M %p}",
        "format-alt": "Ός░  {}"
    },
    "network": {
        "format-wifi" : "{icon} {ipaddr} έΘμ{bandwidthDownBytes} έΘκ{bandwidthUpBytes}",
        "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
        "format-ethernet": "≤░ΑΓ  {ipaddr} έΘμ{bandwidthDownBytes} έΘκ{bandwidthUpBytes}",
        "format-alt" : "≤▒δΘ",
        "format-disconnected" : "≤░Ψς",
        "tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes} έΘκ{bandwidthUpBytes}",
        "tooltip-format-ethernet": "≤░ΑΓ  {ifname}\nέΘμ{bandwidthDownBytes} έΘκ{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "~/.config/rofi/wifi/wifi.sh &",
        "on-click-right": "~/.config/rofi/wifi/wifinew.sh &",
        "interval": 10
    },
    "custom/ip": {
        "interval": "once",
        "signal": 1,
        "format": "Όχς  {}",
        "exec": "cat /tmp/remote-ipv4.log 2>/dev/null || echo Click to get remote IP",
        "tooltip": false,
        "on-click": "curl -s ipv4.icanhazip.com | tee /tmp/remote-ipv4.log && pkill -RTMIN+1 waybar",
        "spacing": 5
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "dynamic-order": ["title", "artist"],
        "player-icons": {
             "default": "ΏθΟ╡",
             "spotify": "ΎΗ╝ ",
             "vlc": "≤░Χ╝ ",
             "firefox": "≤░Ι╣ "
        },
        "status-icons": {
             "paused": "ΎΒΝ "
        }
    }
}]
